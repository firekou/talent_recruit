# Talent Recruit — LinkedIn 人才獵尋系統環境設定
# 複製此檔為 .env，填入真實值後執行腳本
# ⚠ 請勿將 .env 提交到 Git

# ── Anthropic API Key（話術草稿生成）────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Apify API Token（LinkedIn 候選人資料抓取）────────────────
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LinkedIn Session Cookie（li_at）─────────────────────────
# 取得方式（Chrome）：登入 LinkedIn → F12 → Application → Cookies → linkedin.com → li_at
LINKEDIN_LI_AT=AQEDAQ...

# ── Asana CRM 整合────────────────────────────────────────────
# Asana → My Settings → Apps → Personal Access Tokens → Create token
ASANA_TOKEN=1/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Talent Recruit Pipeline 專案的 GID
ASANA_PROJECT_GID=1234567890123456

# ── Make.com Webhook（自動化觸發）───────────────────────────
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Slack Webhook（HOT 候選人即時通知）──────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/WORKSPACE_ID/CHANNEL_ID/TOKEN

# ── 目標職位設定（逗號分隔）──────────────────────────────────
TARGET_ROLES=Business Development Manager,Product Manager,Software Engineer

# ── 目標地區────────────────────────────────────────────────
TARGET_LOCATION=Taiwan
